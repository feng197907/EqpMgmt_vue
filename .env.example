# 数据库配置
DB_TYPE=mysql

# MySQL 配置（云服务器上填写实际值）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password   # 请替换为实际的 MySQL 密码
MYSQL_DATABASE=dms_db

# FastAPI Backend 数据库连接串（覆盖 backend/app/core/config.py 中的默认值）
# 格式: mysql+pymysql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=mysql+pymysql://root:your_mysql_password@127.0.0.1:3306/dms_db
# 注意：密码中含有特殊字符（如 @ : / %）时需 URL 编码，例如 @ → %40

# Flask 配置
FLASK_ENV=production
SECRET_KEY=your-secret-key-change-this-in-production
